# ─────────────────────────────────────────────────────────────────────────────
# E-KART LOCAL ENVIROMENT (.env for Docker Compose)
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE (PostgreSQL) ───
POSTGRES_DB=ecommerce_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ecommerce_db
DB_USERNAME=postgres
DB_PASSWORD=secret

# ─── REDIS ───
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── LARAVEL SHARED ───
APP_ENV=local
APP_DEBUG=true

# Important: these need to be explicitly set inside each service for production.
# But for local docker-compose, setting a default helps.
APP_KEY=base64:RxAZkr+weGFQGtctLlhINgGcESss3bXT2GXy+pqHmmM=

# ─── SERVICES INTERNAL URLS ───
ORDER_SERVICE_URL=http://order-service:8004

# ─── THIRD PARTY SECRETS ───
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
SENDGRID_API_KEY=SG....
MAIL_PASSWORD=${SENDGRID_API_KEY}
MAIL_FROM_ADDRESS=noreply@yourdomain.com

TWILIO_SID=AC...
TWILIO_TOKEN=token...
TWILIO_FROM=+1234567890

# ─── FRONTEND NEXT.JS ───
# Note: Next.js needs these at build time. They are passed as ARGs in docker-compose.yml
# which picks them up from this .env file.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=ecommerce-super-secret-key-change-in-production

# Pointing to the NGINX API Gateway using port 80 via localhost on the host machine
NEXT_PUBLIC_USER_SERVICE_URL=http://localhost
NEXT_PUBLIC_PRODUCT_SERVICE_URL=http://localhost
NEXT_PUBLIC_CART_SERVICE_URL=http://localhost
NEXT_PUBLIC_ORDER_SERVICE_URL=http://localhost
NEXT_PUBLIC_PAYMENT_SERVICE_URL=http://localhost
